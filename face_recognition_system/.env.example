# ===== Recognition =====
SIMILARITY_THRESHOLD=0.45
DETECTOR_SIZE=640
USE_GPU=false

# ===== Liveness =====
LIVENESS_MIN_SCORE=0.5
LIVENESS_REQUIRE_BLINK=false

# ===== Business =====
CHECKIN_COOLDOWN_SECONDS=300

# ===== Storage =====
DATABASE_URL=sqlite:///./data/attendance.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/attendance

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
